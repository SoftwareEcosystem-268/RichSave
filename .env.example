APP_NAME=RichSave
APP_ENV=development

# Application URL and debugging
APP_URL=http://localhost
APP_DEBUG=true

# Server configuration
PORT=3000

# Database configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=richsave
DB_USERNAME=root
DB_PASSWORD=

# Caching / sessions / queues
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Logging
LOG_LEVEL=info

# Authentication / security
JWT_SECRET=

# Third-party services
THIRD_PARTY_API_KEY=